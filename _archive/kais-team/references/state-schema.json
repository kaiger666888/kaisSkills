{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KaisTeam Project State",
  "description": "State file for kais-team project tracking. Stored at projects/<name>/state.json",
  "type": "object",
  "required": ["project", "phase", "mode", "team", "tasks", "checkpoints", "decisions", "createdAt", "lastActive", "updatedAt"],
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name (kebab-case)"
    },
    "phase": {
      "type": "string",
      "enum": ["analyzing", "forming_team", "planning", "executing", "delivering", "completed"],
      "description": "Current project phase"
    },
    "mode": {
      "type": "string",
      "enum": ["normal", "autopilot"],
      "description": "Operating mode: normal (checkpoints ask user) or autopilot (fully autonomous)"
    },
    "goal": {
      "type": "string",
      "description": "Original user goal/description"
    },
    "team": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of skill names assigned to this project"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "skill", "description", "timestamp"],
        "properties": {
          "id": { "type": "string", "description": "Task ID (t1, t2, ...)" },
          "status": { "type": "string", "enum": ["pending", "running", "done", "failed", "blocked"] },
          "skill": { "type": "string", "description": "Assigned skill name" },
          "description": { "type": "string" },
          "output": { "type": "string", "description": "Summary of task output" },
          "artifactHash": { "type": "string", "description": "SHA256 hash of primary artifact (mandatory when task produces files)" },
          "validationError": { "type": "string", "description": "Failure reason when status is 'failed' or 'blocked'" },
          "contextSnapshot": { "type": "string", "description": "Context for interrupt recovery (set on running tasks). Format: { step, outputs, pendingDecisions }" },
          "dependsOn": { "type": "array", "items": { "type": "string" }, "description": "Task IDs this depends on" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "checkpoints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Completed checkpoints: team_confirmed, plan_approved, delivery_accepted"
    },
    "decisions": {
      "type": "array",
      "description": "Decision log (autopilot mode). Records choices made at each checkpoint.",
      "items": {
        "type": "object",
        "properties": {
          "checkpoint": { "type": "integer", "description": "Checkpoint number (1-4)" },
          "options": { "type": "array", "items": { "type": "string" }, "description": "Options considered" },
          "chosen": { "type": "string", "description": "Selected option" },
          "reason": { "type": "string", "description": "Why this option was chosen" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "contextSnapshot": {
      "type": "string",
      "description": "Global context snapshot for recovery (updated each phase transition). Format: { step, outputs, pendingDecisions }"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time", "description": "Last state modification time" },
    "lastActive": { "type": "string", "format": "date-time", "description": "Last time work was active on this project" }
  }
}
